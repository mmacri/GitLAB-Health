{
  "version": 1,
  "updated_on": "2026-03-04",
  "rules": [
    {
      "id": "use_case_scm_green",
      "type": "use_case",
      "condition": {
        "all_capabilities": [
          "scm_repositories_migrated",
          "scm_merge_requests_enabled",
          "scm_review_policies"
        ]
      },
      "outputs": {
        "use_case": "SCM",
        "status": "green"
      },
      "references": [
        "https://docs.gitlab.com/ee/user/project/repository/",
        "https://docs.gitlab.com/ee/user/project/merge_requests/"
      ]
    },
    {
      "id": "use_case_ci_green",
      "type": "use_case",
      "condition": {
        "all_capabilities": [
          "ci_pipeline_templates",
          "ci_shared_runners",
          "ci_test_automation"
        ]
      },
      "outputs": {
        "use_case": "CI",
        "status": "green"
      },
      "references": [
        "https://docs.gitlab.com/ee/ci/"
      ]
    },
    {
      "id": "use_case_cd_green",
      "type": "use_case",
      "condition": {
        "all_capabilities": [
          "cd_environments",
          "cd_release_governance"
        ]
      },
      "outputs": {
        "use_case": "CD",
        "status": "green"
      },
      "references": [
        "https://docs.gitlab.com/ee/ci/environments/",
        "https://docs.gitlab.com/ee/user/project/releases/"
      ]
    },
    {
      "id": "use_case_security_green",
      "type": "use_case",
      "condition": {
        "all_capabilities": [
          "security_sast",
          "security_dependency_scanning"
        ]
      },
      "outputs": {
        "use_case": "Security",
        "status": "green"
      },
      "references": [
        "https://docs.gitlab.com/ee/user/application_security/"
      ]
    },
    {
      "id": "use_case_analytics_green",
      "type": "use_case",
      "condition": {
        "all_capabilities": [
          "analytics_value_stream",
          "analytics_dora_tracking"
        ]
      },
      "outputs": {
        "use_case": "Analytics",
        "status": "green"
      },
      "references": [
        "https://docs.gitlab.com/ee/user/analytics/value_stream_analytics/",
        "https://about.gitlab.com/topics/devops/metrics/"
      ]
    },
    {
      "id": "stage_align",
      "type": "stage",
      "condition": {
        "metric_conditions": [
          { "key": "use_case_green_count", "operator": "==", "value": 0 }
        ]
      },
      "outputs": {
        "journey_stage": "Align",
        "priority": 1
      },
      "references": [
        "https://handbook.gitlab.com/handbook/customer-success/"
      ]
    },
    {
      "id": "stage_onboard",
      "type": "stage",
      "condition": {
        "metric_conditions": [
          { "key": "use_case_green_count", "operator": "==", "value": 1 }
        ]
      },
      "outputs": {
        "journey_stage": "Onboard",
        "priority": 2
      },
      "references": [
        "https://handbook.gitlab.com/handbook/customer-success/onboarding/"
      ]
    },
    {
      "id": "stage_enable",
      "type": "stage",
      "condition": {
        "metric_conditions": [
          { "key": "use_case_green_count", "operator": "==", "value": 2 }
        ]
      },
      "outputs": {
        "journey_stage": "Enable",
        "priority": 3
      },
      "references": [
        "https://handbook.gitlab.com/handbook/customer-success/product-usage-data/platform-value-score/"
      ]
    },
    {
      "id": "stage_expand",
      "type": "stage",
      "condition": {
        "metric_conditions": [
          { "key": "use_case_green_count", "operator": ">=", "value": 3 }
        ],
        "all_capabilities": [
          "operating_exec_alignment"
        ]
      },
      "outputs": {
        "journey_stage": "Expand",
        "priority": 4
      },
      "references": [
        "https://handbook.gitlab.com/handbook/customer-success/product-usage-data/platform-value-score/"
      ]
    },
    {
      "id": "stage_renew",
      "type": "stage",
      "condition": {
        "all_capabilities": [
          "operating_renewal_window_soon"
        ],
        "metric_conditions": [
          { "key": "use_case_green_count", "operator": ">=", "value": 2 }
        ]
      },
      "outputs": {
        "journey_stage": "Renew",
        "priority": 5
      },
      "references": [
        "https://handbook.gitlab.com/handbook/customer-success/renewals/"
      ]
    },
    {
      "id": "action_low_adoption",
      "type": "action",
      "condition": {
        "metric_conditions": [
          { "key": "use_case_green_count", "operator": "<", "value": 3 }
        ]
      },
      "outputs": {
        "title": "Adoption Expansion Needed",
        "description": "Run an Adoption Expansion Workshop to reach 3+ green core use cases.",
        "why": "Use cases implemented: {{use_case_green_count}}. Target is 3+ for platform success.",
        "playbook": "Platform Adoption Expansion Playbook",
        "resource_title": "Platform Value Score",
        "resource_url": "https://handbook.gitlab.com/handbook/customer-success/product-usage-data/platform-value-score/",
        "impact_adjustments": {
          "deployment_frequency": 1,
          "lead_time": 1
        }
      },
      "references": [
        "https://handbook.gitlab.com/handbook/customer-success/product-usage-data/platform-value-score/",
        "https://handbook.gitlab.com/job-families/sales/customer-success-engineer/"
      ]
    },
    {
      "id": "action_ci_enablement_gap",
      "type": "action",
      "condition": {
        "any_missing_capabilities": [
          "ci_pipeline_templates",
          "ci_shared_runners",
          "ci_test_automation"
        ]
      },
      "outputs": {
        "title": "CI Foundations Gap",
        "description": "Run CI Foundations Workshop and standardize pipeline templates and test automation.",
        "why": "CI capabilities are incomplete, limiting delivery velocity and reliability.",
        "playbook": "CI/CD Workshop Playbook",
        "resource_title": "GitLab CI/CD Docs",
        "resource_url": "https://docs.gitlab.com/ee/ci/",
        "impact_adjustments": {
          "deployment_frequency": 1,
          "lead_time": 1,
          "change_failure_rate": 1
        }
      },
      "references": [
        "https://docs.gitlab.com/ee/ci/"
      ]
    },
    {
      "id": "action_cd_enablement_gap",
      "type": "action",
      "condition": {
        "any_missing_capabilities": [
          "cd_environments",
          "cd_release_governance"
        ]
      },
      "outputs": {
        "title": "CD Enablement Gap",
        "description": "Activate environments and release governance to improve release predictability.",
        "why": "CD use case is incomplete, which slows release flow and increases operational risk.",
        "playbook": "Release Orchestration Playbook",
        "resource_title": "GitLab Environments",
        "resource_url": "https://docs.gitlab.com/ee/ci/environments/",
        "impact_adjustments": {
          "deployment_frequency": 1,
          "mttr": 1
        }
      },
      "references": [
        "https://docs.gitlab.com/ee/ci/environments/",
        "https://docs.gitlab.com/ee/user/project/releases/"
      ]
    },
    {
      "id": "action_security_enablement_gap",
      "type": "action",
      "condition": {
        "any_missing_capabilities": [
          "security_sast",
          "security_dependency_scanning"
        ]
      },
      "outputs": {
        "title": "Security Enablement Gap",
        "description": "Schedule Security Enablement Workshop and add baseline scans in pipelines.",
        "why": "Security use case is not fully enabled, reducing risk visibility and control.",
        "playbook": "DevSecOps Capability Expansion Playbook",
        "resource_title": "GitLab Application Security",
        "resource_url": "https://docs.gitlab.com/ee/user/application_security/",
        "impact_adjustments": {
          "change_failure_rate": 1,
          "mttr": 1
        }
      },
      "references": [
        "https://docs.gitlab.com/ee/user/application_security/"
      ]
    },
    {
      "id": "action_analytics_gap",
      "type": "action",
      "condition": {
        "any_missing_capabilities": [
          "analytics_value_stream",
          "analytics_dora_tracking"
        ]
      },
      "outputs": {
        "title": "Value Analytics Gap",
        "description": "Enable Value Stream Analytics and DORA tracking to quantify adoption outcomes.",
        "why": "Outcome visibility is weak without analytics baseline and trend reporting.",
        "playbook": "Value Realization Playbook",
        "resource_title": "Value Stream Analytics",
        "resource_url": "https://docs.gitlab.com/ee/user/analytics/value_stream_analytics/",
        "impact_adjustments": {
          "lead_time": 1
        }
      },
      "references": [
        "https://docs.gitlab.com/ee/user/analytics/value_stream_analytics/",
        "https://about.gitlab.com/topics/devops/metrics/"
      ]
    },
    {
      "id": "action_engagement_cadence_gap",
      "type": "action",
      "condition": {
        "any_missing_capabilities": [
          "operating_cadence_current"
        ]
      },
      "outputs": {
        "title": "Engagement Cadence Gap",
        "description": "Restore monthly engagement cadence and run office hours to unblock technical adoption.",
        "why": "No current engagement cadence signal is active.",
        "playbook": "Office Hours Unblock Playbook",
        "resource_title": "GitLab Learn",
        "resource_url": "https://about.gitlab.com/learn/",
        "impact_adjustments": {
          "lead_time": 1,
          "mttr": 1
        }
      },
      "references": [
        "https://about.gitlab.com/learn/",
        "https://handbook.gitlab.com/handbook/customer-success/"
      ]
    },
    {
      "id": "action_exec_alignment_gap",
      "type": "action",
      "condition": {
        "metric_conditions": [
          { "key": "use_case_green_count", "operator": ">=", "value": 2 }
        ],
        "any_missing_capabilities": [
          "operating_exec_alignment"
        ]
      },
      "outputs": {
        "title": "Executive Alignment Required",
        "description": "Schedule an executive alignment checkpoint and map adoption progress to business outcomes.",
        "why": "Adoption progress exists, but executive alignment is not confirmed.",
        "playbook": "Executive Alignment Playbook",
        "resource_title": "Customer Health Scoring",
        "resource_url": "https://handbook.gitlab.com/handbook/customer-success/customer-health-scoring/",
        "impact_adjustments": {
          "change_failure_rate": 1
        }
      },
      "references": [
        "https://handbook.gitlab.com/handbook/customer-success/customer-health-scoring/"
      ]
    },
    {
      "id": "action_renewal_risk_trigger",
      "type": "action",
      "condition": {
        "all_capabilities": [
          "operating_renewal_window_soon"
        ],
        "metric_conditions": [
          { "key": "use_case_green_count", "operator": "<", "value": 3 }
        ]
      },
      "outputs": {
        "title": "Renewal Readiness Trigger",
        "description": "Run Renewal Readiness Playbook and close adoption gaps before renewal window.",
        "why": "Renewal is near and platform adoption depth is below target.",
        "playbook": "Renewal Readiness Playbook",
        "resource_title": "Renewals Framework",
        "resource_url": "https://handbook.gitlab.com/handbook/customer-success/renewals/",
        "impact_adjustments": {
          "deployment_frequency": 1
        }
      },
      "references": [
        "https://handbook.gitlab.com/handbook/customer-success/renewals/"
      ]
    },
    {
      "id": "action_value_visibility_needed",
      "type": "action",
      "condition": {
        "metric_conditions": [
          { "key": "use_case_green_count", "operator": ">=", "value": 3 }
        ],
        "any_missing_capabilities": [
          "operating_value_metrics_ready"
        ]
      },
      "outputs": {
        "title": "Value Visibility Needed",
        "description": "Prepare Executive Business Review with measurable value metrics and trend evidence.",
        "why": "Adoption depth is strong, but value metrics baseline is not prepared.",
        "playbook": "Executive Business Review (EBR) Playbook",
        "resource_title": "Value Stream Analytics",
        "resource_url": "https://docs.gitlab.com/ee/user/analytics/value_stream_analytics/",
        "impact_adjustments": {
          "change_failure_rate": 1
        }
      },
      "references": [
        "https://docs.gitlab.com/ee/user/analytics/value_stream_analytics/",
        "https://handbook.gitlab.com/handbook/customer-success/customer-health-scoring/"
      ]
    },
    {
      "id": "action_mature_motion",
      "type": "action",
      "condition": {
        "metric_conditions": [
          { "key": "use_case_green_count", "operator": ">=", "value": 4 }
        ],
        "all_capabilities": [
          "operating_exec_alignment",
          "operating_value_metrics_ready",
          "analytics_value_stream"
        ]
      },
      "outputs": {
        "title": "Mature Platform Motion",
        "description": "Sustain momentum with quarterly optimization reviews and expansion planning.",
        "why": "Core adoption and operating signals are strong; focus on scale and strategic outcomes.",
        "playbook": "Quarterly Optimization Playbook",
        "resource_title": "CSE Role Overview",
        "resource_url": "https://handbook.gitlab.com/job-families/sales/customer-success-engineer/",
        "impact_adjustments": {
          "deployment_frequency": 1,
          "lead_time": 1
        }
      },
      "references": [
        "https://handbook.gitlab.com/job-families/sales/customer-success-engineer/",
        "https://about.gitlab.com/stages-devops-lifecycle/"
      ]
    }
  ]
}
